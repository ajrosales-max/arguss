# Anthropic API for AI-assisted remediation explanations
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_EXPLANATION_MODEL=claude-sonnet-4-6

# External APIs (defaults match production; override only if needed)
OSV_API_BASE=https://api.osv.dev
NPM_REGISTRY_BASE=https://registry.npmjs.org
DEPSDEV_API_BASE=https://api.deps.dev/v3
SCORECARD_API_BASE=https://api.scorecard.dev/projects/github.com

# Database
ARGUSS_DB_PATH=./arguss.db #fly is /data/arguss.db
CACHE_TTL_HOURS=24
AI_EXPLANATION_TTL_DAYS=7

# Logging
LOG_LEVEL=INFO

# Demo-period authentication for the hosted web service.
# Leave empty/unset to disable auth (local dev default).
# Set on Fly.io via: flyctl secrets set ARGUSS_DEMO_PASSWORD=<passphrase>
ARGUSS_DEMO_USERNAME=demo
ARGUSS_DEMO_PASSWORD=

# Mode C: concurrency / merge-loop tuning (optional; defaults shown)
MODE_C_CONCURRENCY=5
MODE_C_CI_POLL_INTERVAL_SECONDS=15
MODE_C_CI_GRACE_PERIOD_SECONDS=90
MODE_C_MERGE_WAIT_CAP_SECONDS=1200

# Mode A only: optional read-only GitHub token for Contents API rate limits.
# NOT used for Mode C writes (those use the GitHub App installation token).
# Name must be ARGUSS_GITHUB_TOKEN — GITHUB_PAT_TOKEN is ignored.
ARGUSS_GITHUB_TOKEN=

# GitHub App — required for Mode C (installation tokens + install/OAuth flow)
ARGUSS_GITHUB_APP_ID=
# Base64-encoded PEM private key (no newlines in the env value)
ARGUSS_GITHUB_APP_PRIVATE_KEY_B64=
# OAuth credentials on the GitHub App (user-to-server code exchange)
ARGUSS_GITHUB_APP_CLIENT_ID=
ARGUSS_GITHUB_APP_CLIENT_SECRET=
# Public slug in https://github.com/apps/{slug}/installations/new
ARGUSS_GITHUB_APP_SLUG=
# Signs the arguss_session cookie (OAuth state + verified installation_id).
# Required for /github/install and /github/callback; e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
ARGUSS_SESSION_SECRET=
