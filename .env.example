# Anthropic API for AI-assisted remediation explanations
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_EXPLANATION_MODEL=claude-sonnet-4-6

# External APIs
OSV_API_BASE=https://api.osv.dev
NPM_REGISTRY_BASE=https://registry.npmjs.org
DEPSDEV_API_BASE=https://api.deps.dev/v3

# Database
ARGUSS_DB_PATH=./arguss.db
CACHE_TTL_HOURS=24
AI_EXPLANATION_TTL_DAYS=7

# Logging
LOG_LEVEL=INFO

# Demo-period authentication for the hosted web service.
# Leave empty/unset to disable auth (local dev default).
# Set on Fly.io via: flyctl secrets set ARGUSS_DEMO_PASSWORD=<passphrase>
ARGUSS_DEMO_USERNAME=demo
ARGUSS_DEMO_PASSWORD=

# Mode C: max concurrent PR-open tasks (default 5)
MODE_C_CONCURRENCY=5
